{
	"$schema": "https://schemas.wp.org/wp/6.7/theme.json",
	"version": 3,
	"settings": {
		"appearanceTools": true,
		"color": {
			"defaultDuotone": false,
			"defaultGradients": false,
			"defaultPalette": false,
			"palette": [
				{
					"color": "#642699",
					"name": "Purple",
					"slug": "purple"
				},
				{
					"color": "#5A2A82",
					"name": "Dark Purple",
					"slug": "dark-purple"
				},
				{
					"color": "#1d0631",
					"name": "Extra Dark Purple",
					"slug": "extra-dark-purple"
				},
				{
					"color": "#FFC749",
					"name": "Gold",
					"slug": "gold "
				},
				{
					"color": "#FFFFFF",
					"name": "White",
					"slug": "white"
				},
				{
					"color": "#000000",
					"name": "Black",
					"slug": "black"
				},
				{
					"color": "#F2F2F2",
					"name": "Light Gray",
					"slug": "light-gray"
				},
				{
					"color": "#303030",
					"name": "Dark Gray",
					"slug": "dark-gray"
				}
			]
		},
		"spacing": {
			"defaultSpacingSizes": false,
			"spacingSizes": [
				{
					"name": "XX-Small",
					"size": "10px",
					"slug": "xx-small"
				},
				{
					"name": "X-Small",
					"size": "20px",
					"slug": "x-small"
				},
				{
					"name": "Small",
					"size": "30px",
					"slug": "small"
				},
				{
					"name": "Regular",
					"size": "32px",
					"slug": "regular"
				},
				{
					"name": "Large",
					"size": "clamp(30px, 7vw, 70px)",
					"slug": "large"
				},
				{
					"name": "X-Large",
					"size": "60px",
					"slug": "x-large"
				},
				{
					"name": "XX-Large",
					"size": "clamp(70px, 10vw, 100px)",
					"slug": "xx-large"
				}
			],
			"units": [
				"%",
				"px",
				"em",
				"rem",
				"vh",
				"vw"
			]
		},
		"typography": {
			"writingMode": true,
			"defaultFontSizes": false,
			"fluid": true,
			"fontSizes": [
				{
					"fluid": false,
					"name": "Small",
					"size": "0.875rem",
					"slug": "small"
				},
				{
					"fluid": false,
					"name": "Medium",
					"size": "1rem",
					"slug": "medium"
				},
				{
					"fluid": false,
					"name": "Large",
					"size": "1.125rem",
					"slug": "large"
				},
				{
					"fluid": false,
					"name": "Extra Large",
					"size": "1.625rem",
					"slug": "x-large"
				},
				{
					"fluid": false,
					"name": "Extra Extra Large",
					"size": "3.75rem",
					"slug": "xx-large"
				}
			],
			"fontFamilies": [
				{
					"name": "Roboto",
					"slug": "roboto",
					"fontFamily": "Roboto, sans-serif",
					"fontFace": [
						{
							"src": [
								"file:./assets/fonts/roboto/Roboto.woff2"
							],
							"fontWeight": "400 600 700",
							"fontStyle": "normal",
							"fontFamily": "Roboto"
						}
					]
				}
			]
		},
		"shadow": {
			"defaultPresets": true,
			"presets": [
				{
					"name": "Natural",
					"slug": "natural",
					"shadow": "0 4px 34px 0 rgba(0, 0, 0, 0.25)"
				}
			]

		},
		"useRootPaddingAwareAlignments": true
	},
	"styles": {
		"color": {
			"background": "var:preset|color|white",
			"text": "var:preset|color|dark-gray"
		},
		"spacing": {
			"blockGap": "32px",
			"padding": {
				"left": "30px",
				"right": "30px"
			}
		},
		"typography": {
			"fontFamily": "var:preset|font-family|roboto",
			"fontSize": "var:preset|font-size|medium",
			"fontWeight": "400",
			"lineHeight": "1.23"
		},
		"elements": {
			"heading": {
				"typography": {
					"fontWeight": "400"
				}
			}
		}
	},
	"customTemplates": [
		{
			"name": "page-ebook-redesign",
			"postTypes": ["page"],
			"title": "eBook Redesign"
		}
	]
}
