{
	"name": "blackducktheme",
	"version": "1.0",
	"description": "Black Duck Assessment Theme",
	"author": "McKenna DeBandi",
	"license": "GPL-2.0-or-later",
	"keywords": [
		"WordPress",
		"Theme"
	],
	"homepage": "https://wordpress.org/themes/blackducktheme/",
	"engines": {
		"node": ">=20.10.0",
		"npm": ">=10.2.3"
	},
	"devDependencies": {
		"@wordpress/browserslist-config": "^6.34.0",
		"@wordpress/scripts": "^33.0.0",
		"cssnano": "^7.1.2",
		"postcss": "^8.5.6",
		"postcss-cli": "^11.0.1"
	},
	"browserslist": [
		"extends @wordpress/browserslist-config"
	],
	"scripts": {
		"build": "postcss style.css --use cssnano -o style.min.css --no-map",
		"watch": "postcss style.css --use cssnano -o style.min.css --no-map --watch"
	}
}
